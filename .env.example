# Create a Discord application and invite its bot with View Channels and
# Read Message History permissions. Enable Message Content intent.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Optional comma-separated forum/text channel IDs. When blank, every public
# text, announcement, and forum channel visible to the bot is indexed.
DISCORD_SOURCE_CHANNEL_IDS=

# Protects the manual POST /api/sync endpoint.
ADMIN_SYNC_SECRET=

# Optional tuning. Defaults to 24 and is capped at 48.
MAX_THREADS_PER_SYNC=24
