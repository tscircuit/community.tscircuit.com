# Create a Discord application and invite its bot with View Channels and
# Read Message History permissions. Enable Message Content intent.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Optional comma-separated forum/text channel IDs. IDs take precedence over
# name matching.
DISCORD_SOURCE_CHANNEL_IDS=
DISCORD_SOURCE_CHANNEL_NAMES=support,contributor

# Exclude messages authored by these comma-separated bot/user names.
DISCORD_IGNORED_AUTHORS=AnswerOverflow

# Post one quiet backlink into each active indexed thread.
DISCORD_POST_BACKLINKS=true
PUBLIC_SITE_URL=https://tscircuit-community-index.seveibar.chatgpt.site

# Protects the manual POST /api/sync endpoint.
ADMIN_SYNC_SECRET=

# Optional tuning. Thread processing is capped at 48 per refresh.
MAX_THREADS_PER_SYNC=48
SYNC_INTERVAL_MINUTES=15
